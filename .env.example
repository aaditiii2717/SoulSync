
# 1. Google Gemini AI Integration
# Get your API Key here: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Supabase Configuration
# Get these from: Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 3. (Optional) Google Maps Static API
# Needed for the Crisis Map nearby centers view
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# 4. Security / Admin Seeds
# Initial admins seeded in your database migration:
# admin@soulsync.org, manager@soulsync.org
